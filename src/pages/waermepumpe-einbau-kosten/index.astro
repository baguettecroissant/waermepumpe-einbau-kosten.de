---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { siteConfig } from '../../../site.config';
import { getAllStates, getCitiesByState } from '../../lib/cities';

const states = getAllStates();
const title = `Wärmepumpe Einbau Kosten: Regionale Preisübersicht | ${siteConfig.name}`;
const description = `Finden Sie die Einbaukosten für Luft-Wasser-Wärmepumpen in über 1.100 Städten deutschlandweit. Regionale Preise, Förderung und Angebote im Detail.`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Wärmepumpen Einbaukosten - Regionale Übersicht",
    "description": description,
    "url": "https://" + siteConfig.domain + "/waermepumpe-einbau-kosten/",
  }
];
---

<BaseLayout title={title} description={description} canonical="/waermepumpe-einbau-kosten/" jsonLd={jsonLd}>
  <!-- Hero Section -->
  <section class="gradient-hero text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Städte & Regionen", href: "/waermepumpe-einbau-kosten/" },
      ]} />
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4 font-heading mt-6">
        📍 Regionale Einbaukosten & Angebote vergleichen
      </h1>
      <p class="text-brand-50 text-lg max-w-2xl">
        Wählen Sie Ihre Region oder Ihre Stadt aus, um die detaillierten Anschaffungskosten, örtlichen Netzbetreiber, Landesbauordnungen und Angebote zertifizierter Heizungsbauer vor Ort einzusehen.
      </p>
    </div>
  </section>

  <!-- States Quick Navigation -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
      <h2 class="text-lg font-bold text-gray-900 mb-4 font-heading">🗺️ Bundesländer Übersicht</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {states.map(state => (
          <a href={`#state-${state.name.toLowerCase().replace(/[^a-z0-9]/g, '-')}`} class="bg-gray-50 border border-gray-200 rounded-xl px-4 py-2.5 text-center hover:border-brand-200 hover:shadow-sm transition-all group">
            <span class="block text-xs font-semibold text-gray-900 group-hover:text-brand-700 font-heading">{state.name}</span>
            <span class="text-[10px] text-gray-500 font-data">{state.count} Städte</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Cities Grouped by State -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 space-y-12">
    {states.map(state => {
      const stateCities = getCitiesByState(state.name);
      return (
        <div id={`state-${state.name.toLowerCase().replace(/[^a-z0-9]/g, '-')}`} class="bg-white rounded-2xl border border-gray-200 p-6 md:p-8 shadow-sm space-y-6 scroll-mt-24">
          <div class="border-b border-gray-100 pb-4">
            <h2 class="text-xl font-bold text-gray-900 font-heading">
              🇩🇪 Wärmepumpen-Einbau in {state.name}
            </h2>
            <p class="text-xs text-gray-500 mt-1">
              Verfügbare Städte und Gemeinden für Heizungsinstallationen in {state.name} ({state.count} Standorte):
            </p>
          </div>
          
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
            {stateCities.map(city => (
              <a 
                href={`/waermepumpe-einbau-kosten/${city.slug}/`} 
                class="bg-[#FAFAFA] border border-gray-200 rounded-xl px-3 py-2.5 hover:border-brand-200 hover:shadow-md transition-all group text-center card-hover flex flex-col justify-center min-h-[60px]"
              >
                <span class="font-semibold text-gray-900 group-hover:text-brand-700 text-xs md:text-sm block font-heading leading-tight">{city.name}</span>
                <span class="text-[10px] text-gray-500 mt-0.5 font-data">{city.zip}</span>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </section>
</BaseLayout>
